# Copy to backend/.env.production ON THE SERVER and fill with REAL values.
# DB host is the compose SERVICE name "postgres" (not localhost). The password
# here must match POSTGRES_PASSWORD in the root .env.
DATABASE_URL=postgresql://postgres:__POSTGRES_PASSWORD__@postgres:5432/udyogi_hrms

# Generate with: openssl rand -hex 32
SECRET_KEY=__GENERATE_A_STRONG_SECRET__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MUST match the key the seed dump's data was encrypted with, or aadhaar/bank
# columns will not decrypt. (For the test DB, this is your local ENCRYPTION_KEY.)
ENCRYPTION_KEY=__SAME_AS_THE_KEY_THE_DUMP_WAS_ENCRYPTED_WITH__

ENVIRONMENT=production
UPLOAD_DIR=uploads

# Email payslips (Session 22 #5) — get these from IT. Leave SMTP_HOST blank to
# disable email. SMTP_FROM defaults to SMTP_USER when blank.
#   Company SMTP (LAN relay):   SMTP_HOST=mail.udyogi.local  SMTP_PORT=25   SMTP_TLS=false  (no auth)
#   Gmail/Workspace app pwd:    SMTP_HOST=smtp.gmail.com      SMTP_PORT=587  SMTP_TLS=true   SMTP_USER/SMTP_PASSWORD set
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
# Auto-send previous month's payslips on this day-of-month at this hour (server local time).
EMAIL_PAYSLIP_DAY=4
EMAIL_PAYSLIP_HOUR=9
